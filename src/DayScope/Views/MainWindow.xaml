<Window x:Class="DayScope.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:day="clr-namespace:DayScope.Application.DaySchedule;assembly=DayScope.Application"
        Title="DayScope"
        Width="920"
        Height="680"
        MinWidth="660"
        MinHeight="500"
        Background="#14171B"
        ResizeMode="CanResize"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <FontFamily x:Key="UiFont">Segoe UI Variable Display, Segoe UI, Arial</FontFamily>

        <Style x:Key="SlimScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="Background" Value="#6F8599" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="10" />
            <Setter Property="Background" Value="#11161B" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Width="{TemplateBinding Width}"
                              Background="Transparent">
                            <Border Margin="2,0,0,0"
                                    Background="#101419"
                                    CornerRadius="6" />
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  Focusable="False"
                                                  Opacity="0" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource SlimScrollBarThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  Focusable="False"
                                                  Opacity="0" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="0" />
                    <Setter Property="Visibility" Value="Collapsed" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HourLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#8D9AA8" />
        </Style>

        <Style x:Key="EventCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#395267" />
            <Setter Property="BorderBrush" Value="#4F6E88" />
            <Setter Property="Opacity" Value="1" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Appearance}" Value="{x:Static day:EventAppearance.AwaitingResponse}">
                    <Setter Property="Background" Value="#5B4929" />
                    <Setter Property="BorderBrush" Value="#C79F52" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Appearance}" Value="{x:Static day:EventAppearance.Tentative}">
                    <Setter Property="Background" Value="#345663" />
                    <Setter Property="BorderBrush" Value="#63A6C0" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Appearance}" Value="{x:Static day:EventAppearance.Declined}">
                    <Setter Property="Background" Value="#2C3640" />
                    <Setter Property="BorderBrush" Value="#68798A" />
                    <Setter Property="Opacity" Value="0.72" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Appearance}" Value="{x:Static day:EventAppearance.Cancelled}">
                    <Setter Property="Background" Value="#2C3137" />
                    <Setter Property="BorderBrush" Value="#A76464" />
                    <Setter Property="Opacity" Value="0.58" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="EventTitleStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#ECF6FF" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Appearance}" Value="{x:Static day:EventAppearance.AwaitingResponse}">
                    <Setter Property="Foreground" Value="#FFF1CE" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Appearance}" Value="{x:Static day:EventAppearance.Declined}">
                    <Setter Property="TextDecorations" Value="Strikethrough" />
                    <Setter Property="Foreground" Value="#D5DFE7" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Appearance}" Value="{x:Static day:EventAppearance.Cancelled}">
                    <Setter Property="TextDecorations" Value="Strikethrough" />
                    <Setter Property="Foreground" Value="#E7D3D3" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="EventMetaStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#BFD6E9" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Appearance}" Value="{x:Static day:EventAppearance.AwaitingResponse}">
                    <Setter Property="Foreground" Value="#F0D8A4" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Appearance}" Value="{x:Static day:EventAppearance.Declined}">
                    <Setter Property="TextDecorations" Value="Strikethrough" />
                    <Setter Property="Foreground" Value="#B2C0CC" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Appearance}" Value="{x:Static day:EventAppearance.Cancelled}">
                    <Setter Property="TextDecorations" Value="Strikethrough" />
                    <Setter Property="Foreground" Value="#CBAFAF" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="EventBadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="#4F6E88" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Appearance}" Value="{x:Static day:EventAppearance.AwaitingResponse}">
                    <Setter Property="Background" Value="#C79F52" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Appearance}" Value="{x:Static day:EventAppearance.Tentative}">
                    <Setter Property="Background" Value="#63A6C0" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Appearance}" Value="{x:Static day:EventAppearance.Declined}">
                    <Setter Property="Background" Value="#68798A" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Appearance}" Value="{x:Static day:EventAppearance.Cancelled}">
                    <Setter Property="Background" Value="#A76464" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Vertical">
                <TextBlock FontFamily="{StaticResource UiFont}"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="#F5F7FA"
                           Text="{Binding MonthTitle}" />
                <TextBlock Margin="0,6,0,0"
                           FontFamily="{StaticResource UiFont}"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="#7C8794"
                           Text="{Binding DateText}" />
            </StackPanel>

            <Border Grid.Column="1"
                    Height="48"
                    Padding="14,5"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="#191F27"
                    BorderBrush="#2A313B"
                    BorderThickness="1"
                    CornerRadius="14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               VerticalAlignment="Center"
                               FontFamily="{StaticResource UiFont}"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="#F5F7FA"
                               Text="{Binding DayTitle}" />

                    <Border Grid.Column="2"
                            Width="22"
                            Height="30"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Background="#F46556"
                            CornerRadius="8">
                        <TextBlock FontFamily="{StaticResource UiFont}"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Text="{Binding DayNumberText}" />
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="1"
              Margin="0,16,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="56" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="{Binding SecondaryTimeColumnWidth}" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Style="{StaticResource HourLabelStyle}"
                       Text="{Binding PrimaryTimeZoneLabel}" />

            <TextBlock Grid.Column="2"
                       Style="{StaticResource HourLabelStyle}"
                       Text="{Binding SecondaryTimeZoneLabel}"
                       Visibility="{Binding HasSecondaryTimeZone, Converter={StaticResource BoolToVisibilityConverter}}" />

            <TextBlock Grid.Column="4"
                       FontFamily="{StaticResource UiFont}"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="#B8C1CB"
                       Text="All-day" />
        </Grid>

        <Border Grid.Row="2"
                Background="#181B20"
                BorderBrush="#262C35"
                BorderThickness="1"
                CornerRadius="20">
            <ScrollViewer x:Name="ScheduleScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="12,12,10,16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="56" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="{Binding SecondaryTimeColumnWidth}" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="4"
                                MinHeight="42"
                                Padding="10,8"
                                Background="#151A20"
                                BorderBrush="#242C36"
                                BorderThickness="1"
                                CornerRadius="10">
                            <Grid>
                                <ItemsControl ItemsSource="{Binding AllDayEvents}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,10,6"
                                                    Padding="8,5"
                                                    CornerRadius="7"
                                                    Style="{StaticResource EventCardStyle}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Margin="0,0,8,0"
                                                               TextTrimming="CharacterEllipsis">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock" BasedOn="{StaticResource EventTitleStyle}">
                                                                <Setter Property="FontSize" Value="12" />
                                                            </Style>
                                                        </TextBlock.Style>
                                                        <Run Text="{Binding LeadingIcon}" />
                                                        <Run Text="{Binding Title}" />
                                                    </TextBlock>
                                                    <Border Grid.Column="1"
                                                            Padding="6,2"
                                                            VerticalAlignment="Center"
                                                            CornerRadius="6"
                                                            Style="{StaticResource EventBadgeStyle}">
                                                        <TextBlock FontFamily="{StaticResource UiFont}"
                                                                   FontSize="9"
                                                                   FontWeight="Bold"
                                                                   Foreground="White"
                                                                   Text="{Binding StatusLabel}" />
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock FontFamily="{StaticResource UiFont}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#6E7A87"
                                           Text="No all-day events">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding AllDayEvents.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="1"
                          Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="56" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="{Binding SecondaryTimeColumnWidth}" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <ItemsControl Grid.Column="0"
                                      Height="{Binding TimelineHeight}"
                                      ItemsSource="{Binding PrimaryTimelineHours}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Top" Value="{Binding Top}" />
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Style="{StaticResource HourLabelStyle}"
                                               Text="{Binding Text}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ItemsControl Grid.Column="2"
                                      Height="{Binding TimelineHeight}"
                                      ItemsSource="{Binding SecondaryTimelineHours}"
                                      Visibility="{Binding HasSecondaryTimeZone, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Top" Value="{Binding Top}" />
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Style="{StaticResource HourLabelStyle}"
                                               Text="{Binding Text}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border x:Name="ScheduleSurfaceBorder"
                                Grid.Column="4"
                                MinWidth="420"
                                Height="{Binding TimelineHeight}"
                                Background="#161A1F"
                                BorderBrush="#242B35"
                                BorderThickness="1"
                                CornerRadius="12">
                            <Grid>
                                <ItemsControl Height="{Binding TimelineHeight}"
                                              Width="{Binding ScheduleCanvasWidth}"
                                              ItemsSource="{Binding PrimaryTimelineHours}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <Canvas />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Canvas.Top" Value="{Binding Top}" />
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="{Binding DataContext.ScheduleCanvasWidth, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    Height="1"
                                                    Background="#242B35" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <ItemsControl Height="{Binding TimelineHeight}"
                                              Width="{Binding ScheduleCanvasWidth}"
                                              ItemsSource="{Binding TimedEvents}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <Canvas />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Canvas.Top" Value="{Binding Top}" />
                                            <Setter Property="Canvas.Left" Value="{Binding Left}" />
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="{Binding Width}"
                                                    Height="{Binding Height}"
                                                    Padding="8,6"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Style="{StaticResource EventCardStyle}">
                                                <StackPanel>
                                                    <DockPanel LastChildFill="False">
                                                        <Border DockPanel.Dock="Right"
                                                                Padding="6,2"
                                                                Margin="8,0,0,0"
                                                                VerticalAlignment="Top"
                                                                CornerRadius="6"
                                                                Style="{StaticResource EventBadgeStyle}">
                                                            <TextBlock FontFamily="{StaticResource UiFont}"
                                                                       FontSize="9"
                                                                       FontWeight="Bold"
                                                                       Foreground="White"
                                                                       Text="{Binding StatusLabel}" />
                                                        </Border>
                                                        <TextBlock TextTrimming="CharacterEllipsis"
                                                                   Style="{StaticResource EventTitleStyle}">
                                                            <Run Text="{Binding LeadingIcon}" />
                                                            <Run Text="{Binding Title}" />
                                                        </TextBlock>
                                                    </DockPanel>
                                                    <TextBlock Margin="0,4,0,0"
                                                               Text="{Binding ScheduleText}"
                                                               Style="{StaticResource EventMetaStyle}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Canvas Width="{Binding ScheduleCanvasWidth}"
                                        Height="{Binding TimelineHeight}"
                                        Visibility="{Binding ShowNowLine, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Border Width="{Binding DataContext.ScheduleCanvasWidth, RelativeSource={RelativeSource AncestorType=Canvas}}"
                                            Height="2"
                                            Background="#FF5A4D"
                                            Canvas.Top="{Binding NowLineTop}" />
                                </Canvas>

                                <Border Width="320"
                                        Padding="12,10"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Top"
                                        Background="#101419"
                                        BorderBrush="#2A313B"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Visibility="{Binding ShowStatus, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock FontFamily="{StaticResource UiFont}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="#A9B4C0"
                                               Text="{Binding StatusText}"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap" />
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>

<Window x:Class="DayScope.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:day="clr-namespace:DayScope.Application.DaySchedule;assembly=DayScope.Application"
        xmlns:view="clr-namespace:DayScope.Views"
        Title="DayScope"
        Width="920"
        Height="680"
        MinWidth="660"
        MinHeight="500"
        Background="#14171B"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <FontFamily x:Key="UiFont">Segoe UI Variable Display, Segoe UI, Arial</FontFamily>

        <Style x:Key="SlimScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="Background" Value="#6F8599" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="10" />
            <Setter Property="Background" Value="#11161B" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Width="{TemplateBinding Width}"
                              Background="Transparent">
                            <Border Margin="2,0,0,0"
                                    Background="#101419"
                                    CornerRadius="6" />
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  Focusable="False"
                                                  Opacity="0" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource SlimScrollBarThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  Focusable="False"
                                                  Opacity="0" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="0" />
                    <Setter Property="Visibility" Value="Collapsed" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HourLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#8D9AA8" />
        </Style>

        <Style x:Key="EventCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#395267" />
            <Setter Property="BorderBrush" Value="#4F6E88" />
            <Setter Property="Opacity" Value="1" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Appearance}" Value="{x:Static day:EventAppearance.AwaitingResponse}">
                    <Setter Property="Background" Value="#5B4929" />
                    <Setter Property="BorderBrush" Value="#C79F52" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Appearance}" Value="{x:Static day:EventAppearance.Tentative}">
                    <Setter Property="Background" Value="#345663" />
                    <Setter Property="BorderBrush" Value="#63A6C0" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Appearance}" Value="{x:Static day:EventAppearance.Declined}">
                    <Setter Property="Background" Value="#2C3640" />
                    <Setter Property="BorderBrush" Value="#68798A" />
                    <Setter Property="Opacity" Value="0.72" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Appearance}" Value="{x:Static day:EventAppearance.Cancelled}">
                    <Setter Property="Background" Value="#2C3137" />
                    <Setter Property="BorderBrush" Value="#A76464" />
                    <Setter Property="Opacity" Value="0.58" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="EventTitleStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#ECF6FF" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Appearance}" Value="{x:Static day:EventAppearance.AwaitingResponse}">
                    <Setter Property="Foreground" Value="#FFF1CE" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Appearance}" Value="{x:Static day:EventAppearance.Declined}">
                    <Setter Property="TextDecorations" Value="Strikethrough" />
                    <Setter Property="Foreground" Value="#D5DFE7" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Appearance}" Value="{x:Static day:EventAppearance.Cancelled}">
                    <Setter Property="TextDecorations" Value="Strikethrough" />
                    <Setter Property="Foreground" Value="#E7D3D3" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="EventMetaStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#BFD6E9" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Appearance}" Value="{x:Static day:EventAppearance.AwaitingResponse}">
                    <Setter Property="Foreground" Value="#F0D8A4" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Appearance}" Value="{x:Static day:EventAppearance.Declined}">
                    <Setter Property="TextDecorations" Value="Strikethrough" />
                    <Setter Property="Foreground" Value="#B2C0CC" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Appearance}" Value="{x:Static day:EventAppearance.Cancelled}">
                    <Setter Property="TextDecorations" Value="Strikethrough" />
                    <Setter Property="Foreground" Value="#CBAFAF" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="EventBadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="#4F6E88" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Appearance}" Value="{x:Static day:EventAppearance.AwaitingResponse}">
                    <Setter Property="Background" Value="#C79F52" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Appearance}" Value="{x:Static day:EventAppearance.Tentative}">
                    <Setter Property="Background" Value="#63A6C0" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Appearance}" Value="{x:Static day:EventAppearance.Declined}">
                    <Setter Property="Background" Value="#68798A" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Appearance}" Value="{x:Static day:EventAppearance.Cancelled}">
                    <Setter Property="Background" Value="#A76464" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModalActionButtonStyle" TargetType="Button">
            <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#F5F7FA" />
            <Setter Property="Background" Value="#2F6FED" />
            <Setter Property="BorderBrush" Value="#2F6FED" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="MinWidth" Value="164" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModalSecondaryActionButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource ModalActionButtonStyle}">
            <Setter Property="Foreground" Value="#D7E4F2" />
            <Setter Property="Background" Value="#1A2330" />
            <Setter Property="BorderBrush" Value="#39506A" />
        </Style>

        <Style x:Key="HeaderShortcutButtonStyle" TargetType="Button">
            <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
            <Setter Property="Background" Value="#191F27" />
            <Setter Property="BorderBrush" Value="#2A313B" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#415163" />
                                <Setter TargetName="Chrome" Property="Background" Value="#1C232C" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#4B5C71" />
                                <Setter TargetName="Chrome" Property="Background" Value="#202935" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="UnreadEmailBadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="#445669" />
            <Setter Property="CornerRadius" Value="10" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding UnreadEmailCount}" Value="{x:Null}">
                    <Setter Property="Background" Value="#5A6572" />
                </DataTrigger>
                <DataTrigger Binding="{Binding HasUnreadEmails}" Value="True">
                    <Setter Property="Background" Value="#F46556" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HeaderNavButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource HeaderShortcutButtonStyle}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="0" />
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Vertical">
                <TextBlock FontFamily="{StaticResource UiFont}"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="#F5F7FA"
                           Text="{Binding MonthTitle}" />
                <TextBlock Margin="0,6,0,0"
                           FontFamily="{StaticResource UiFont}"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="#7C8794"
                           Text="{Binding DateText}" />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <Button Margin="0,0,10,0"
                        ToolTip="Previous day"
                        Style="{StaticResource HeaderNavButtonStyle}"
                        Click="OnPreviousDayClickAsync">
                    <TextBlock FontFamily="{StaticResource UiFont}"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="#E3EBF4"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Text="&lt;" />
                </Button>

                <Button Height="48"
                        Padding="14,5"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        ToolTip="Open Google Calendar"
                        Style="{StaticResource HeaderShortcutButtonStyle}"
                        Click="OnOpenGoogleCalendarClick">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   VerticalAlignment="Center"
                                   FontFamily="{StaticResource UiFont}"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="#F5F7FA"
                                   Text="{Binding DayTitle}" />

                        <Border Grid.Column="2"
                                Width="22"
                                Height="30"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Background="#F46556"
                                CornerRadius="8">
                            <TextBlock FontFamily="{StaticResource UiFont}"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Text="{Binding DayNumberText}" />
                        </Border>
                    </Grid>
                </Button>

                <Button Margin="10,0,0,0"
                        ToolTip="Next day"
                        Style="{StaticResource HeaderNavButtonStyle}"
                        Click="OnNextDayClickAsync">
                    <TextBlock FontFamily="{StaticResource UiFont}"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="#E3EBF4"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Text="&gt;" />
                </Button>
            </StackPanel>

            <Button Grid.Column="2"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    ToolTip="{Binding UnreadEmailSummaryText}"
                    Style="{StaticResource HeaderShortcutButtonStyle}"
                    Click="OnOpenUnreadEmailsClick">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               VerticalAlignment="Center"
                               FontFamily="{StaticResource UiFont}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#E3EBF4"
                               Text="Unread Emails" />

                    <Border Grid.Column="2"
                            MinWidth="38"
                            Height="28"
                            Padding="10,0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Style="{StaticResource UnreadEmailBadgeStyle}">
                        <TextBlock FontFamily="{StaticResource UiFont}"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Text="{Binding UnreadEmailCountText}" />
                    </Border>
                </Grid>
            </Button>
        </Grid>

        <Grid Grid.Row="1"
              Margin="0,16,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{Binding PrimaryTimeColumnWidth}" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="{Binding SecondaryTimeColumnWidth}" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Style="{StaticResource HourLabelStyle}"
                       TextTrimming="CharacterEllipsis"
                       Text="{Binding PrimaryTimeZoneLabel}" />

            <TextBlock Grid.Column="2"
                       Style="{StaticResource HourLabelStyle}"
                       TextTrimming="CharacterEllipsis"
                       Text="{Binding SecondaryTimeZoneLabel}"
                       Visibility="{Binding HasSecondaryTimeZone, Converter={StaticResource BoolToVisibilityConverter}}" />

            <TextBlock Grid.Column="4"
                       FontFamily="{StaticResource UiFont}"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="#B8C1CB"
                       Text="All-day" />
        </Grid>

        <Border Grid.Row="2"
                Background="#181B20"
                BorderBrush="#262C35"
                BorderThickness="1"
                CornerRadius="20">
            <ScrollViewer x:Name="ScheduleScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="12,12,10,16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="{Binding PrimaryTimeColumnWidth}" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="{Binding SecondaryTimeColumnWidth}" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="4"
                                MinHeight="42"
                                Padding="10,8"
                                Background="#151A20"
                                BorderBrush="#242C36"
                                BorderThickness="1"
                                CornerRadius="10">
                            <Grid>
                                <ItemsControl ItemsSource="{Binding AllDayEvents}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,10,6"
                                                    Padding="8,5"
                                                    CornerRadius="7"
                                                    Cursor="Hand"
                                                    MouseLeftButtonUp="OnEventCardMouseLeftButtonUp"
                                                    Style="{StaticResource EventCardStyle}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Margin="0,0,8,0"
                                                               TextTrimming="CharacterEllipsis">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock" BasedOn="{StaticResource EventTitleStyle}">
                                                                <Setter Property="FontSize" Value="12" />
                                                            </Style>
                                                        </TextBlock.Style>
                                                        <Run Text="{Binding LeadingIcon}" />
                                                        <Run Text="{Binding Title}" />
                                                    </TextBlock>
                                                    <Border Grid.Column="1"
                                                            Padding="6,2"
                                                            VerticalAlignment="Center"
                                                            CornerRadius="6"
                                                            Style="{StaticResource EventBadgeStyle}">
                                                        <TextBlock FontFamily="{StaticResource UiFont}"
                                                                   FontSize="9"
                                                                   FontWeight="Bold"
                                                                   Foreground="White"
                                                                   Text="{Binding StatusLabel}" />
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock FontFamily="{StaticResource UiFont}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#6E7A87"
                                           Text="No all-day events">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding AllDayEvents.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="1"
                          Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="{Binding PrimaryTimeColumnWidth}" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="{Binding SecondaryTimeColumnWidth}" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <ItemsControl Grid.Column="0"
                                      Height="{Binding TimelineHeight}"
                                      ItemsSource="{Binding PrimaryTimelineHours}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Top" Value="{Binding Top}" />
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Style="{StaticResource HourLabelStyle}"
                                               Text="{Binding Text}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ItemsControl Grid.Column="2"
                                      Height="{Binding TimelineHeight}"
                                      ItemsSource="{Binding SecondaryTimelineHours}"
                                      Visibility="{Binding HasSecondaryTimeZone, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Top" Value="{Binding Top}" />
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Style="{StaticResource HourLabelStyle}"
                                               Text="{Binding Text}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border x:Name="ScheduleSurfaceBorder"
                                Grid.Column="4"
                                MinWidth="420"
                                Height="{Binding TimelineHeight}"
                                Background="#161A1F"
                                BorderBrush="#242B35"
                                BorderThickness="1"
                                CornerRadius="12">
                            <Grid>
                                <ItemsControl Height="{Binding TimelineHeight}"
                                              Width="{Binding ScheduleCanvasWidth}"
                                              ItemsSource="{Binding PrimaryTimelineHours}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <Canvas />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Canvas.Top" Value="{Binding Top}" />
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="{Binding DataContext.ScheduleCanvasWidth, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    Height="1"
                                                    Background="#242B35" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <ItemsControl Height="{Binding TimelineHeight}"
                                              Width="{Binding ScheduleCanvasWidth}"
                                              ItemsSource="{Binding TimedEvents}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <Canvas />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Canvas.Top" Value="{Binding Top}" />
                                            <Setter Property="Canvas.Left" Value="{Binding Left}" />
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="{Binding Width}"
                                                    Height="{Binding Height}"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Cursor="Hand"
                                                    MouseLeftButtonUp="OnEventCardMouseLeftButtonUp"
                                                    VerticalAlignment="Top">
                                                <Border.Style>
                                                    <Style TargetType="Border" BasedOn="{StaticResource EventCardStyle}">
                                                        <Setter Property="Padding" Value="8,6" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCompact}" Value="True">
                                                                <Setter Property="Padding" Value="7,4" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsMicro}" Value="True">
                                                                <Setter Property="Padding" Value="7,2" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel>
                                                    <DockPanel LastChildFill="False">
                                                        <Border DockPanel.Dock="Right"
                                                                Padding="6,2"
                                                                Margin="8,0,0,0"
                                                                VerticalAlignment="Top"
                                                                CornerRadius="6">
                                                            <Border.Style>
                                                                <Style TargetType="Border" BasedOn="{StaticResource EventBadgeStyle}">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding ShowStatusBadge}" Value="False">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock FontFamily="{StaticResource UiFont}"
                                                                       FontSize="9"
                                                                       FontWeight="Bold"
                                                                       Foreground="White"
                                                                       Text="{Binding StatusLabel}" />
                                                        </Border>
                                                        <TextBlock TextTrimming="CharacterEllipsis">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock" BasedOn="{StaticResource EventTitleStyle}">
                                                                    <Setter Property="FontSize" Value="13" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsCompact}" Value="True">
                                                                            <Setter Property="FontSize" Value="12" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                            <Run Text="{Binding LeadingIcon}" />
                                                            <Run Text="{Binding Title}" />
                                                        </TextBlock>
                                                    </DockPanel>
                                                    <TextBlock Margin="0,4,0,0"
                                                               Text="{Binding ScheduleText}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock" BasedOn="{StaticResource EventMetaStyle}">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding ShowScheduleText}" Value="False">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Canvas Width="{Binding ScheduleCanvasWidth}"
                                        Height="{Binding TimelineHeight}"
                                        Visibility="{Binding ShowNowLine, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Border Width="{Binding DataContext.ScheduleCanvasWidth, RelativeSource={RelativeSource AncestorType=Canvas}}"
                                            Height="2"
                                            Background="#FF5A4D"
                                            Canvas.Top="{Binding NowLineTop}" />
                                </Canvas>

                                <Border Width="320"
                                        Padding="12,10"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Top"
                                        Background="#101419"
                                        BorderBrush="#2A313B"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Visibility="{Binding ShowStatus, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock FontFamily="{StaticResource UiFont}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="#A9B4C0"
                                               Text="{Binding StatusText}"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap" />
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </ScrollViewer>
        </Border>

        <Grid Grid.RowSpan="3"
              Panel.ZIndex="20"
              Visibility="{Binding IsEventDetailsOpen, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Background="#B2000000"
                    MouseLeftButtonUp="OnEventDetailsOverlayMouseLeftButtonUp" />

            <Border Width="520"
                    MaxWidth="520"
                    MaxHeight="620"
                    Padding="18"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="#1A1F26"
                    BorderBrush="#313A46"
                    BorderThickness="1"
                    CornerRadius="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0"
                                    Margin="0,0,12,0">
                            <TextBlock FontFamily="{StaticResource UiFont}"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="#F5F7FA"
                                       TextWrapping="Wrap"
                                       MaxWidth="420">
                                <Run Text="{Binding SelectedEventDetails.LeadingIcon}" />
                                <Run Text="{Binding SelectedEventDetails.Title}" />
                            </TextBlock>
                            <TextBlock Margin="0,8,0,0"
                                       FontFamily="{StaticResource UiFont}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#9AA7B6"
                                       Text="{Binding SelectedEventDetails.ScheduleText}" />
                            <Border Margin="0,10,0,0"
                                    Padding="8,3"
                                    HorizontalAlignment="Left"
                                    CornerRadius="7"
                                    Style="{StaticResource EventBadgeStyle}"
                                    DataContext="{Binding SelectedEventDetails}">
                                <TextBlock FontFamily="{StaticResource UiFont}"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           Foreground="White"
                                           Text="{Binding StatusLabel}" />
                            </Border>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Width="30"
                                Height="30"
                                Background="#222A34"
                                BorderBrush="#384555"
                                BorderThickness="1"
                                Click="OnCloseEventDetailsClick"
                                Cursor="Hand">
                            <TextBlock FontFamily="{StaticResource UiFont}"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="#D9E3EC"
                                       Text="Г—"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Button>
                    </Grid>

                    <ScrollViewer Grid.Row="1"
                                  Margin="0,18,0,0"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <StackPanel Margin="0,0,0,16"
                                        Visibility="{Binding HasSelectedEventOrganizer, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock FontFamily="{StaticResource UiFont}"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Foreground="#7F8B99"
                                           Text="Author" />
                                <TextBlock Margin="0,6,0,0"
                                           FontFamily="{StaticResource UiFont}"
                                           FontSize="13"
                                           Foreground="#E2EAF2"
                                           Text="{Binding SelectedEventDetails.Organizer}" />
                            </StackPanel>

                            <StackPanel Margin="0,0,0,16"
                                        Visibility="{Binding HasSelectedEventDescription, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock FontFamily="{StaticResource UiFont}"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Foreground="#7F8B99"
                                           Text="Description" />
                                <Border Margin="0,6,0,0"
                                        Padding="12"
                                        Background="#141920"
                                        BorderBrush="#2A3440"
                                        BorderThickness="1"
                                        CornerRadius="10">
                                    <TextBlock FontFamily="{StaticResource UiFont}"
                                               FontSize="13"
                                               Foreground="#D7E1EA"
                                               view:HtmlTextBlock.Html="{Binding SelectedEventDetails.Description}"
                                               TextWrapping="Wrap" />
                                </Border>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,16"
                                        Visibility="{Binding HasSelectedEventParticipants, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock FontFamily="{StaticResource UiFont}"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Foreground="#7F8B99"
                                           Text="Participants" />
                                <ItemsControl Margin="0,8,0,0"
                                              ItemsSource="{Binding SelectedEventDetails.Participants}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,8"
                                                    Padding="10,8"
                                                    Background="#141920"
                                                    BorderBrush="#2A3440"
                                                    BorderThickness="1"
                                                    CornerRadius="10">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Grid.Column="0"
                                                                Orientation="Horizontal">
                                                        <TextBlock FontFamily="{StaticResource UiFont}"
                                                                   FontSize="13"
                                                                   Foreground="#E2EAF2"
                                                                   Text="{Binding DisplayName}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Margin="4,0,0,0"
                                                                   FontFamily="{StaticResource UiFont}"
                                                                   FontSize="12"
                                                                   Foreground="#9FB0C1"
                                                                   Text="(you)"
                                                                   Visibility="{Binding IsSelf, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                    </StackPanel>

                                                    <TextBlock Grid.Column="1"
                                                               Margin="12,0,0,0"
                                                               FontFamily="{StaticResource UiFont}"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="#98A8B8"
                                                               Text="{Binding StatusLabel}" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <StackPanel Visibility="{Binding HasSelectedEventJoinUrl, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock FontFamily="{StaticResource UiFont}"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Foreground="#7F8B99"
                                           Text="Meeting" />
                                <StackPanel Margin="0,8,0,0">
                                    <TextBlock FontFamily="{StaticResource UiFont}"
                                               FontSize="12"
                                               Foreground="#9FB0C1"
                                               Text="{Binding SelectedEventDetails.JoinUrl}"
                                               TextTrimming="CharacterEllipsis" />
                                    <StackPanel Margin="0,12,0,0"
                                                Orientation="Horizontal">
                                        <Button Margin="0,0,10,10"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Top"
                                                Style="{StaticResource ModalActionButtonStyle}"
                                                Click="OnOpenEventLinkClick"
                                                Content="{Binding SelectedEventJoinLabel}" />
                                        <Button Margin="0,0,0,10"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Top"
                                                Style="{StaticResource ModalSecondaryActionButtonStyle}"
                                                Click="OnCopyEventLinkClick"
                                                Content="Copy link" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>

<Window x:Class="DayScope.Views.MainWindow"
        x:Name="RootWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:day="clr-namespace:DayScope.Application.DaySchedule;assembly=DayScope.Application"
        xmlns:view="clr-namespace:DayScope.Views"
        Title="DayScope"
        Width="920"
        Height="680"
        MinWidth="660"
        MinHeight="500"
        Background="{DynamicResource WindowBackgroundBrush}"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <FontFamily x:Key="UiFont">Segoe UI Variable Display, Segoe UI, Arial</FontFamily>

        <Style x:Key="SlimScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="Background" Value="{DynamicResource ScrollThumbBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="10" />
            <Setter Property="Background" Value="{DynamicResource ScrollBarBackgroundBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Width="{TemplateBinding Width}"
                              Margin="0,8,0,8"
                              Background="Transparent">
                            <Border Margin="2,0,0,0"
                                    Background="{DynamicResource SubtleBackgroundBrush}"
                                    CornerRadius="6" />
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  Focusable="False"
                                                  Opacity="0" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource SlimScrollBarThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  Focusable="False"
                                                  Opacity="0" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="0" />
                    <Setter Property="Visibility" Value="Collapsed" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HourLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource HourLabelBrush}" />
        </Style>

        <Style x:Key="EventCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource EventAcceptedBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource EventAcceptedAccentBrush}" />
            <Setter Property="Opacity" Value="1" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Appearance}" Value="{x:Static day:EventAppearance.AwaitingResponse}">
                    <Setter Property="Background" Value="{DynamicResource EventAwaitingBackgroundBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource EventAwaitingAccentBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Appearance}" Value="{x:Static day:EventAppearance.Tentative}">
                    <Setter Property="Background" Value="{DynamicResource EventTentativeBackgroundBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource EventTentativeAccentBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Appearance}" Value="{x:Static day:EventAppearance.Declined}">
                    <Setter Property="Background" Value="{DynamicResource EventDeclinedBackgroundBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource EventDeclinedAccentBrush}" />
                    <Setter Property="Opacity" Value="0.72" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Appearance}" Value="{x:Static day:EventAppearance.Cancelled}">
                    <Setter Property="Background" Value="{DynamicResource EventCancelledBackgroundBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource EventCancelledAccentBrush}" />
                    <Setter Property="Opacity" Value="0.58" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="EventTitleStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource EventTitleBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Appearance}" Value="{x:Static day:EventAppearance.AwaitingResponse}">
                    <Setter Property="Foreground" Value="{DynamicResource EventAwaitingTitleBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Appearance}" Value="{x:Static day:EventAppearance.Declined}">
                    <Setter Property="TextDecorations" Value="Strikethrough" />
                    <Setter Property="Foreground" Value="{DynamicResource EventDeclinedTitleBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Appearance}" Value="{x:Static day:EventAppearance.Cancelled}">
                    <Setter Property="TextDecorations" Value="Strikethrough" />
                    <Setter Property="Foreground" Value="{DynamicResource EventCancelledTitleBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="EventMetaStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{DynamicResource EventMetaBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Appearance}" Value="{x:Static day:EventAppearance.AwaitingResponse}">
                    <Setter Property="Foreground" Value="{DynamicResource EventAwaitingMetaBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Appearance}" Value="{x:Static day:EventAppearance.Declined}">
                    <Setter Property="TextDecorations" Value="Strikethrough" />
                    <Setter Property="Foreground" Value="{DynamicResource EventDeclinedMetaBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Appearance}" Value="{x:Static day:EventAppearance.Cancelled}">
                    <Setter Property="TextDecorations" Value="Strikethrough" />
                    <Setter Property="Foreground" Value="{DynamicResource EventCancelledMetaBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="EventBadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource EventAcceptedAccentBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Appearance}" Value="{x:Static day:EventAppearance.AwaitingResponse}">
                    <Setter Property="Background" Value="{DynamicResource EventAwaitingAccentBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Appearance}" Value="{x:Static day:EventAppearance.Tentative}">
                    <Setter Property="Background" Value="{DynamicResource EventTentativeAccentBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Appearance}" Value="{x:Static day:EventAppearance.Declined}">
                    <Setter Property="Background" Value="{DynamicResource EventDeclinedAccentBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Appearance}" Value="{x:Static day:EventAppearance.Cancelled}">
                    <Setter Property="Background" Value="{DynamicResource EventCancelledAccentBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModalActionButtonStyle" TargetType="Button">
            <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="{DynamicResource PrimaryActionBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryActionBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="MinWidth" Value="164" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModalSecondaryActionButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource ModalActionButtonStyle}">
            <Setter Property="Foreground" Value="{DynamicResource SecondaryActionTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource SecondaryActionBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SecondaryActionBorderBrush}" />
        </Style>

        <Style x:Key="HeaderShortcutButtonStyle" TargetType="Button">
            <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Background" Value="{DynamicResource HeaderSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource HeaderHoverBorderBrush}" />
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource HeaderHoverBackgroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource HeaderPressedBorderBrush}" />
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource HeaderPressedBackgroundBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="UnreadEmailBadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource UnreadBadgeBrush}" />
            <Setter Property="CornerRadius" Value="10" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Inbox.UnreadEmailCount}" Value="{x:Null}">
                    <Setter Property="Background" Value="{DynamicResource UnreadBadgeUnknownBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Inbox.HasUnreadEmails}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentDangerBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HeaderNavButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource HeaderShortcutButtonStyle}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style x:Key="HeaderMenuButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource HeaderShortcutButtonStyle}">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="44" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style x:Key="HeaderMenuPopupButtonStyle" TargetType="Button">
            <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource HeaderHoverBackgroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource HeaderPressedBackgroundBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderMenuPopupSubButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource HeaderMenuPopupButtonStyle}">
            <Setter Property="Padding" Value="14,8" />
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.RowSpan="3"
              Margin="-18"
              IsHitTestVisible="False"
              ClipToBounds="True">
            <Rectangle Fill="{DynamicResource ThemeBackdropOverlayBrush}" />

            <Ellipse Width="680"
                     Height="340"
                     Margin="-150,-220,0,0"
                     HorizontalAlignment="Left"
                     VerticalAlignment="Top"
                     Fill="{DynamicResource ThemeSurfaceGlowBrush}" />

            <Viewbox Stretch="Fill">
                <Canvas Width="1000"
                        Height="720">
                    <Path Fill="{DynamicResource ThemeLightRayBrush}"
                          Data="M 88,0 L 176,0 L 310,540 L 194,540 Z" />
                    <Path Fill="{DynamicResource ThemeLightRayBrush}"
                          Data="M 272,0 L 364,0 L 534,560 L 412,560 Z" />
                    <Path Fill="{DynamicResource ThemeLightRayBrush}"
                          Data="M 512,0 L 600,0 L 734,530 L 620,530 Z" />

                    <Path Fill="{DynamicResource ThemeSeabedBrush}"
                          Data="M 0,552 C 122,510 250,532 360,576 C 470,620 612,624 744,592 C 852,566 938,554 1000,572 L 1000,720 L 0,720 Z" />

                    <Path Stroke="{DynamicResource ThemeSeaweedSecondaryBrush}"
                          StrokeThickness="7"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          Data="M 70,694 C 62,646 78,606 98,570 C 118,534 128,494 116,446" />
                    <Path Stroke="{DynamicResource ThemeSeaweedBrush}"
                          StrokeThickness="8"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          Data="M 114,698 C 108,646 126,602 150,566 C 174,528 184,494 172,454" />
                    <Path Stroke="{DynamicResource ThemeSeaweedSecondaryBrush}"
                          StrokeThickness="7"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          Data="M 166,700 C 162,656 176,618 196,586 C 216,552 228,516 222,480" />
                    <Path Stroke="{DynamicResource ThemeSeaweedBrush}"
                          StrokeThickness="8"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          Data="M 850,700 C 842,648 856,606 882,568 C 906,534 918,498 910,454" />
                    <Path Stroke="{DynamicResource ThemeSeaweedSecondaryBrush}"
                          StrokeThickness="7"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          Data="M 908,702 C 900,654 914,612 934,580 C 952,550 964,514 958,482" />

                    <Path Stroke="{DynamicResource ThemeCoralBrush}"
                          StrokeThickness="8"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          StrokeLineJoin="Round"
                          Data="M 790,662 C 784,620 784,584 790,546 M 790,574 C 766,550 748,526 734,492 M 792,586 C 820,558 838,530 848,494 M 796,622 C 826,608 852,586 870,560" />
                    <Path Stroke="{DynamicResource ThemeCoralSecondaryBrush}"
                          StrokeThickness="7"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          StrokeLineJoin="Round"
                          Data="M 258,668 C 252,630 252,598 258,566 M 258,590 C 236,572 220,550 208,524 M 262,606 C 286,586 300,562 306,534 M 264,634 C 286,626 304,612 320,594" />
                </Canvas>
            </Viewbox>
        </Grid>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Vertical">
                <TextBlock FontFamily="{StaticResource UiFont}"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           Text="{Binding Schedule.MonthTitle}" />
                <TextBlock Margin="0,6,0,0"
                           FontFamily="{StaticResource UiFont}"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Text="{Binding Schedule.DateText}" />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <Button Margin="0,0,10,0"
                        ToolTip="Previous day"
                        Style="{StaticResource HeaderNavButtonStyle}"
                        Click="OnPreviousDayClickAsync">
                    <TextBlock FontFamily="{StaticResource UiFont}"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="{DynamicResource HeaderTextBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Text="&lt;" />
                </Button>

                <Button Height="48"
                        Padding="14,5"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        ToolTip="Open Google Calendar"
                        Style="{StaticResource HeaderShortcutButtonStyle}"
                        Click="OnOpenGoogleCalendarClick">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   VerticalAlignment="Center"
                                   FontFamily="{StaticResource UiFont}"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Text="{Binding Schedule.DayTitle}" />

                        <Border Grid.Column="2"
                                Width="22"
                                Height="30"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Background="{DynamicResource AccentDangerBrush}"
                                CornerRadius="8">
                            <TextBlock FontFamily="{StaticResource UiFont}"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Text="{Binding Schedule.DayNumberText}" />
                        </Border>
                    </Grid>
                </Button>

                <Button Margin="10,0,0,0"
                        ToolTip="Next day"
                        Style="{StaticResource HeaderNavButtonStyle}"
                        Click="OnNextDayClickAsync">
                    <TextBlock FontFamily="{StaticResource UiFont}"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="{DynamicResource HeaderTextBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Text="&gt;" />
                </Button>
            </StackPanel>

            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <Button ToolTip="{Binding Inbox.UnreadEmailSummaryText}"
                        Style="{StaticResource HeaderShortcutButtonStyle}"
                        Click="OnOpenUnreadEmailsClick">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   VerticalAlignment="Center"
                                   FontFamily="{StaticResource UiFont}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource HeaderTextBrush}"
                                   Text="Emails" />

                        <Border Grid.Column="2"
                                MinWidth="38"
                                Height="28"
                                Padding="10,0"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Style="{StaticResource UnreadEmailBadgeStyle}">
                            <TextBlock FontFamily="{StaticResource UiFont}"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Text="{Binding Inbox.UnreadEmailCountText}" />
                        </Border>
                    </Grid>
                </Button>

                <Grid Margin="10,0,0,0">
                    <Button x:Name="HeaderMenuButton"
                            ToolTip="Settings"
                            Style="{StaticResource HeaderMenuButtonStyle}"
                            ClickMode="Press"
                            Click="OnToggleHeaderMenuClick">
                        <Path Width="18"
                              Height="14"
                              Stretch="Fill"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Stroke="{DynamicResource HeaderTextBrush}"
                              StrokeThickness="1.8"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Data="M 2,2 L 16,2 M 2,7 L 16,7 M 2,12 L 16,12" />
                    </Button>

                    <Popup x:Name="HeaderMenuPopup"
                           Placement="Bottom"
                           PlacementTarget="{Binding ElementName=HeaderMenuButton}"
                           VerticalOffset="10"
                           AllowsTransparency="True"
                           PopupAnimation="Fade"
                           StaysOpen="False"
                           Closed="OnHeaderMenuClosed">
                        <Border MinWidth="244"
                                Padding="8"
                                Background="{DynamicResource CardBackgroundBrush}"
                                BorderBrush="{DynamicResource CardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="18">
                            <StackPanel>
                                <Button Style="{StaticResource HeaderMenuPopupButtonStyle}"
                                        Click="OnHideToTrayClick">
                                    <TextBlock FontFamily="{StaticResource UiFont}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               Text="Hide to tray" />
                                </Button>

                                <Button Style="{StaticResource HeaderMenuPopupButtonStyle}"
                                        Click="OnRefreshFromHeaderMenuClickAsync">
                                    <TextBlock FontFamily="{StaticResource UiFont}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               Text="Refresh now" />
                                </Button>

                                <Button Style="{StaticResource HeaderMenuPopupButtonStyle}"
                                        Click="OnToggleSecondaryTimeZoneClick"
                                        Visibility="{Binding Schedule.HasConfiguredSecondaryTimeZone, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="18" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Path Width="10"
                                              Height="8"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Stroke="{DynamicResource AccentDangerBrush}"
                                              StrokeThickness="1.8"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              Visibility="{Binding Schedule.ShowSecondaryTimeZone, Converter={StaticResource BoolToVisibilityConverter}}"
                                              Data="M 1,4 L 4,7 L 9,1" />
                                        <TextBlock Grid.Column="1"
                                                   FontFamily="{StaticResource UiFont}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   Text="Show secondary time zone" />
                                    </Grid>
                                </Button>

                                <Button Style="{StaticResource HeaderMenuPopupButtonStyle}"
                                        Click="OnToggleThemeMenuClick">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock FontFamily="{StaticResource UiFont}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   Text="Theme" />
                                        <TextBlock Grid.Column="1"
                                                   FontFamily="{StaticResource UiFont}"
                                                   FontSize="14"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Text="&gt;" />
                                    </Grid>
                                </Button>

                                <Border x:Name="ThemeMenuItemsPanel"
                                        Margin="0,4,0,0"
                                        Padding="6,0,0,0"
                                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                                        BorderThickness="1,0,0,0"
                                        Visibility="Collapsed">
                                    <ItemsControl ItemsSource="{Binding ElementName=RootWindow, Path=ThemeMenuOptions}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Style="{StaticResource HeaderMenuPopupSubButtonStyle}"
                                                        Click="OnThemeModeMenuItemClick">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="18" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>

                                                        <Ellipse Width="6"
                                                                 Height="6"
                                                                 Fill="{DynamicResource AccentDangerBrush}"
                                                                 HorizontalAlignment="Center"
                                                                 VerticalAlignment="Center"
                                                                 Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                        <TextBlock Grid.Column="1"
                                                                   FontFamily="{StaticResource UiFont}"
                                                                   FontSize="12"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   Text="{Binding Label}">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="FontWeight" Value="Normal" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                            <Setter Property="FontWeight" Value="SemiBold" />
                                                                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Grid>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>

                                <Border Height="1"
                                        Margin="6,8"
                                        Background="{DynamicResource BorderSubtleBrush}" />

                                <Button Style="{StaticResource HeaderMenuPopupButtonStyle}"
                                        Click="OnExitFromHeaderMenuClick">
                                    <TextBlock FontFamily="{StaticResource UiFont}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               Text="Exit" />
                                </Button>
                            </StackPanel>
                        </Border>
                    </Popup>
                </Grid>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1"
              Margin="0,16,0,8">
            <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="{Binding Schedule.PrimaryTimeColumnWidth}" />
                <ColumnDefinition Width="{Binding Schedule.SecondaryTimeZoneLeadingGapWidth}" />
                    <ColumnDefinition Width="{Binding Schedule.SecondaryTimeColumnWidth}" />
                <ColumnDefinition Width="{Binding Schedule.SecondaryTimeZoneTrailingGapWidth}" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Style="{StaticResource HourLabelStyle}"
                       TextTrimming="CharacterEllipsis"
                               Text="{Binding Schedule.PrimaryTimeZoneLabel}" />

            <TextBlock Grid.Column="2"
                       Style="{StaticResource HourLabelStyle}"
                       TextTrimming="CharacterEllipsis"
                                Text="{Binding Schedule.SecondaryTimeZoneLabel}"
                       Visibility="{Binding Schedule.HasSecondaryTimeZone, Converter={StaticResource BoolToVisibilityConverter}}" />

            <TextBlock Grid.Column="4"
                       FontFamily="{StaticResource UiFont}"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextMutedBrush}"
                       Text="All-day" />
        </Grid>

        <Border Grid.Row="2"
                Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="20">
            <ScrollViewer x:Name="ScheduleScrollViewer"
                          view:SmoothScrollBehavior.IsEnabled="True"
                          view:SmoothScrollBehavior.WheelStep="88.1"
                          view:SmoothScrollBehavior.AnimationDuration="0:0:0.22"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="12,12,10,16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="{Binding Schedule.PrimaryTimeColumnWidth}" />
                            <ColumnDefinition Width="{Binding Schedule.SecondaryTimeZoneLeadingGapWidth}" />
                    <ColumnDefinition Width="{Binding Schedule.SecondaryTimeColumnWidth}" />
                            <ColumnDefinition Width="{Binding Schedule.SecondaryTimeZoneTrailingGapWidth}" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="4"
                                MinHeight="42"
                                Padding="10,8"
                                Background="{DynamicResource SecondarySurfaceBrush}"
                                BorderBrush="{DynamicResource SecondarySurfaceBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10">
                            <Grid>
                        <ItemsControl ItemsSource="{Binding Schedule.AllDayEvents}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,10,6"
                                                    Padding="8,5"
                                                    CornerRadius="7"
                                                    Cursor="Hand"
                                                    MouseLeftButtonUp="OnEventCardMouseLeftButtonUp"
                                                    Style="{StaticResource EventCardStyle}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Margin="0,0,8,0"
                                                               TextTrimming="CharacterEllipsis">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock" BasedOn="{StaticResource EventTitleStyle}">
                                                                <Setter Property="FontSize" Value="12" />
                                                            </Style>
                                                        </TextBlock.Style>
                                                        <Run Text="{Binding LeadingIcon}" />
                                                        <Run Text="{Binding Title}" />
                                                    </TextBlock>
                                                    <Border Grid.Column="1"
                                                            Padding="6,2"
                                                            VerticalAlignment="Center"
                                                            CornerRadius="6"
                                                            Style="{StaticResource EventBadgeStyle}">
                                                        <TextBlock FontFamily="{StaticResource UiFont}"
                                                                   FontSize="9"
                                                                   FontWeight="Bold"
                                                                   Foreground="White"
                                                                   Text="{Binding StatusLabel}" />
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock FontFamily="{StaticResource UiFont}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource EmptyStateTextBrush}"
                                           Text="No all-day events">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                            <DataTrigger Binding="{Binding Schedule.AllDayEvents.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="1"
                          Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="{Binding Schedule.PrimaryTimeColumnWidth}" />
                            <ColumnDefinition Width="{Binding Schedule.SecondaryTimeZoneLeadingGapWidth}" />
                    <ColumnDefinition Width="{Binding Schedule.SecondaryTimeColumnWidth}" />
                            <ColumnDefinition Width="{Binding Schedule.SecondaryTimeZoneTrailingGapWidth}" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <ItemsControl Grid.Column="0"
                              Height="{Binding Schedule.TimelineHeight}"
                              ItemsSource="{Binding Schedule.PrimaryTimelineHours}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Top" Value="{Binding Top}" />
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Style="{StaticResource HourLabelStyle}"
                                               Text="{Binding Text}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ItemsControl Grid.Column="2"
                              Height="{Binding Schedule.TimelineHeight}"
                              ItemsSource="{Binding Schedule.SecondaryTimelineHours}"
                                      Visibility="{Binding Schedule.HasSecondaryTimeZone, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Top" Value="{Binding Top}" />
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Style="{StaticResource HourLabelStyle}"
                                               Text="{Binding Text}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border x:Name="ScheduleSurfaceBorder"
                                Grid.Column="4"
                                MinWidth="420"
                              Height="{Binding Schedule.TimelineHeight}"
                                Background="{DynamicResource ScheduleSurfaceBackgroundBrush}"
                                BorderBrush="{DynamicResource ScheduleSurfaceBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12">
                            <Grid>
                                <ItemsControl Height="{Binding Schedule.TimelineHeight}"
                                              Width="{Binding Schedule.ScheduleCanvasWidth}"
                                              ItemsSource="{Binding Schedule.PrimaryTimelineHours}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <Canvas />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Canvas.Top" Value="{Binding Top}" />
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="{Binding DataContext.Schedule.ScheduleCanvasWidth, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    Height="1"
                                                    Background="{DynamicResource ScheduleSurfaceBorderBrush}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <ItemsControl Height="{Binding Schedule.TimelineHeight}"
                                              Width="{Binding Schedule.ScheduleCanvasWidth}"
                                              ItemsSource="{Binding Schedule.TimedEvents}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <Canvas />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Canvas.Top" Value="{Binding Top}" />
                                            <Setter Property="Canvas.Left" Value="{Binding Left}" />
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="{Binding Width}"
                                                    Height="{Binding Height}"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Cursor="Hand"
                                                    MouseLeftButtonUp="OnEventCardMouseLeftButtonUp"
                                                    VerticalAlignment="Top">
                                                <Border.Style>
                                                    <Style TargetType="Border" BasedOn="{StaticResource EventCardStyle}">
                                                        <Setter Property="Padding" Value="8,6" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCompact}" Value="True">
                                                                <Setter Property="Padding" Value="7,4" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsMicro}" Value="True">
                                                                <Setter Property="Padding" Value="7,2" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel>
                                                    <DockPanel LastChildFill="False">
                                                        <Border DockPanel.Dock="Right"
                                                                Padding="6,2"
                                                                Margin="8,0,0,0"
                                                                VerticalAlignment="Top"
                                                                CornerRadius="6">
                                                            <Border.Style>
                                                                <Style TargetType="Border" BasedOn="{StaticResource EventBadgeStyle}">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding ShowStatusBadge}" Value="False">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock FontFamily="{StaticResource UiFont}"
                                                                       FontSize="9"
                                                                       FontWeight="Bold"
                                                                       Foreground="White"
                                                                       Text="{Binding StatusLabel}" />
                                                        </Border>
                                                        <TextBlock TextTrimming="CharacterEllipsis">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock" BasedOn="{StaticResource EventTitleStyle}">
                                                                    <Setter Property="FontSize" Value="13" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsCompact}" Value="True">
                                                                            <Setter Property="FontSize" Value="12" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                            <Run Text="{Binding LeadingIcon}" />
                                                            <Run Text="{Binding Title}" />
                                                        </TextBlock>
                                                    </DockPanel>
                                                    <TextBlock Margin="0,4,0,0"
                                                               Text="{Binding ScheduleText}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock" BasedOn="{StaticResource EventMetaStyle}">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding ShowScheduleText}" Value="False">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Canvas Width="{Binding Schedule.ScheduleCanvasWidth}"
                                        Height="{Binding Schedule.TimelineHeight}"
                                        Visibility="{Binding Schedule.ShowNowLine, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Border Width="{Binding DataContext.Schedule.ScheduleCanvasWidth, RelativeSource={RelativeSource AncestorType=Canvas}}"
                                            Height="2"
                                            Background="{DynamicResource NowLineBrush}"
                                            Canvas.Top="{Binding Schedule.NowLineTop}" />
                                </Canvas>

                                <Border Width="320"
                                        Padding="12,10"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Top"
                                        Background="{DynamicResource SubtleBackgroundBrush}"
                                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Visibility="{Binding Schedule.ShowStatus, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock FontFamily="{StaticResource UiFont}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource StatusTextBrush}"
                                               Text="{Binding Schedule.StatusText}"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap" />
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </ScrollViewer>
        </Border>

        <Grid Grid.RowSpan="3"
              Margin="-18"
              Panel.ZIndex="20"
              Visibility="{Binding EventDetails.IsOpen, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Background="{DynamicResource OverlayBrush}"
                    CornerRadius="24"
                    MouseLeftButtonUp="OnEventDetailsOverlayMouseLeftButtonUp" />

            <Border Width="520"
                    MaxWidth="520"
                    MaxHeight="620"
                    Margin="24"
                    Padding="18"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{DynamicResource ModalBackgroundBrush}"
                    BorderBrush="{DynamicResource ModalBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0"
                                    Margin="0,0,12,0">
                            <TextBlock FontFamily="{StaticResource UiFont}"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       TextWrapping="Wrap"
                                       MaxWidth="420">
                                <Run Text="{Binding EventDetails.SelectedEventDetails.LeadingIcon}" />
                                <Run Text="{Binding EventDetails.SelectedEventDetails.Title}" />
                            </TextBlock>
                            <TextBlock Margin="0,8,0,0"
                                       FontFamily="{StaticResource UiFont}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource ModalSecondaryTextBrush}"
                                       Text="{Binding EventDetails.SelectedEventDetails.ScheduleText}" />
                            <Border Margin="0,10,0,0"
                                    Padding="8,3"
                                    HorizontalAlignment="Left"
                                    CornerRadius="7"
                                    Style="{StaticResource EventBadgeStyle}"
                                    DataContext="{Binding EventDetails.SelectedEventDetails}">
                                <TextBlock FontFamily="{StaticResource UiFont}"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           Foreground="White"
                                           Text="{Binding StatusLabel}" />
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <Button Width="58"
                                    Height="30"
                                    Margin="0,0,8,0"
                                    Padding="10,0"
                                    FocusVisualStyle="{x:Null}"
                                    Background="{DynamicResource CloseButtonBackgroundBrush}"
                                    BorderBrush="{DynamicResource CloseButtonBorderBrush}"
                                    BorderThickness="1"
                                    Click="OnCopyEventDetailsClick"
                                    Cursor="Hand"
                                    ToolTip="Copy title, time and description">
                                <TextBlock FontFamily="{StaticResource UiFont}"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource CloseButtonTextBrush}"
                                           Text="Copy"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Button>

                            <Button Width="30"
                                    Height="30"
                                    FocusVisualStyle="{x:Null}"
                                    Background="{DynamicResource CloseButtonBackgroundBrush}"
                                    BorderBrush="{DynamicResource CloseButtonBorderBrush}"
                                    BorderThickness="1"
                                    Click="OnCloseEventDetailsClick"
                                    Cursor="Hand">
                                <TextBlock FontFamily="{StaticResource UiFont}"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource CloseButtonTextBrush}"
                                           Text="X"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Button>
                        </StackPanel>
                    </Grid>

                    <ScrollViewer Grid.Row="1"
                                  view:SmoothScrollBehavior.IsEnabled="True"
                                  view:SmoothScrollBehavior.WheelStep="88.1"
                                  view:SmoothScrollBehavior.AnimationDuration="0:0:0.22"
                                  Margin="0,18,0,0"
                                  Focusable="False"
                                  FocusVisualStyle="{x:Null}"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <StackPanel Margin="0,0,0,16"
                                        Visibility="{Binding EventDetails.HasOrganizer, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock FontFamily="{StaticResource UiFont}"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource SectionLabelBrush}"
                                           Text="Author" />
                                <TextBlock Margin="0,6,0,0"
                                           FontFamily="{StaticResource UiFont}"
                                           FontSize="13"
                                           Foreground="{DynamicResource BodyTextBrush}"
                                           Text="{Binding EventDetails.SelectedEventDetails.Organizer}" />
                            </StackPanel>

                            <StackPanel Margin="0,0,0,16"
                                        Visibility="{Binding EventDetails.HasDescription, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock FontFamily="{StaticResource UiFont}"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource SectionLabelBrush}"
                                           Text="Description" />
                                <Border Margin="0,6,0,0"
                                        Padding="12"
                                        Background="{DynamicResource ModalInsetBackgroundBrush}"
                                        BorderBrush="{DynamicResource ModalInsetBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10">
                                    <TextBlock FontFamily="{StaticResource UiFont}"
                                               FontSize="13"
                                               Foreground="{DynamicResource ModalInsetTextBrush}"
                                               view:HtmlTextBlock.Html="{Binding EventDetails.SelectedEventDetails.Description}"
                                               TextWrapping="Wrap" />
                                </Border>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,16"
                                        Visibility="{Binding EventDetails.HasParticipants, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock FontFamily="{StaticResource UiFont}"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource SectionLabelBrush}"
                                           Text="Participants" />
                                <ItemsControl Margin="0,8,0,0"
                                              ItemsSource="{Binding EventDetails.SelectedEventDetails.Participants}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,8"
                                                    Padding="10,8"
                                                    Background="{DynamicResource ModalInsetBackgroundBrush}"
                                                    BorderBrush="{DynamicResource ModalInsetBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="10">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Grid.Column="0"
                                                                Orientation="Horizontal">
                                                        <TextBlock FontFamily="{StaticResource UiFont}"
                                                                   FontSize="13"
                                                                   Foreground="{DynamicResource BodyTextBrush}"
                                                                   Text="{Binding DisplayName}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Margin="4,0,0,0"
                                                                   FontFamily="{StaticResource UiFont}"
                                                                   FontSize="12"
                                                                   Foreground="{DynamicResource BodySubtleTextBrush}"
                                                                   Text="(you)"
                                                                   Visibility="{Binding IsSelf, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                    </StackPanel>

                                                    <TextBlock Grid.Column="1"
                                                               Margin="12,0,0,0"
                                                               FontFamily="{StaticResource UiFont}"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource ParticipantStatusBrush}"
                                                               Text="{Binding StatusLabel}" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <StackPanel Visibility="{Binding EventDetails.HasJoinUrl, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock FontFamily="{StaticResource UiFont}"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource SectionLabelBrush}"
                                           Text="Meeting" />
                                <StackPanel Margin="0,8,0,0">
                                    <TextBlock FontFamily="{StaticResource UiFont}"
                                               FontSize="12"
                                               Foreground="{DynamicResource BodySubtleTextBrush}"
                                               Text="{Binding EventDetails.SelectedEventDetails.JoinUrl}"
                                               TextTrimming="CharacterEllipsis" />
                                    <StackPanel Margin="0,12,0,0"
                                                Orientation="Horizontal">
                                        <Button Margin="0,0,10,10"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Top"
                                                Style="{StaticResource ModalActionButtonStyle}"
                                                Click="OnOpenEventLinkClick"
                                                Content="{Binding EventDetails.JoinLabel}" />
                                        <Button Margin="0,0,0,10"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Top"
                                                Style="{StaticResource ModalSecondaryActionButtonStyle}"
                                                Click="OnCopyEventLinkClick"
                                                Content="Copy link" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>

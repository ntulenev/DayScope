<Application x:Class="DayScope.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="ThemeBackdropOverlayBrush" Color="#00FFFFFF" />
        <RadialGradientBrush x:Key="ThemeSurfaceGlowBrush"
                             Center="0.5,0.08"
                             GradientOrigin="0.5,0.08"
                             RadiusX="0.42"
                             RadiusY="0.26">
            <GradientStop Color="#00FFFFFF" Offset="0" />
            <GradientStop Color="#00FFFFFF" Offset="1" />
        </RadialGradientBrush>
        <LinearGradientBrush x:Key="ThemeLightRayBrush"
                             StartPoint="0.5,0"
                             EndPoint="0.5,1">
            <GradientStop Color="#00FFFFFF" Offset="0" />
            <GradientStop Color="#00FFFFFF" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="ThemeSeabedBrush"
                             StartPoint="0.5,0"
                             EndPoint="0.5,1">
            <GradientStop Color="#00FFFFFF" Offset="0" />
            <GradientStop Color="#00FFFFFF" Offset="1" />
        </LinearGradientBrush>
        <SolidColorBrush x:Key="ThemeSeaweedBrush" Color="#00FFFFFF" />
        <SolidColorBrush x:Key="ThemeSeaweedSecondaryBrush" Color="#00FFFFFF" />
        <SolidColorBrush x:Key="ThemeCoralBrush" Color="#00FFFFFF" />
        <SolidColorBrush x:Key="ThemeCoralSecondaryBrush" Color="#00FFFFFF" />
    </Application.Resources>
</Application>
